rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if user is admin
    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid))
        && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.isAdmin == true;
    }

    // Books collection - public read, admin-only write
    match /books/{bookId} {
      allow read: if true;  // Anyone can read books
      allow create, update, delete: if isAdmin();
    }

    // Requests collection - public create, admin-only read/update
    match /requests/{requestId} {
      allow create: if request.resource.data.status == 'pending';
      allow read, update, delete: if isAdmin();
    }

    // Admins collection - self-read only, no write (managed via Admin SDK)
    match /admins/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;  // Only writable via Firebase Admin SDK
    }

    // Metadata collection - public read, admin-only write
    match /metadata/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
